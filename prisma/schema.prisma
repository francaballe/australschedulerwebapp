generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  schemas           = ["app"]
}

model Company {
  id   Int    @id @default(autoincrement())
  name String

  users            User[]
  sites            Site[]
  positions        Position[]
  shifts           Shift[]
  unavailabilities UserUnavailability[]
  pushTokens       UserPushToken[]
  messages         Message[]
  confirmedWeeks   ConfirmedWeek[]
  logs             Log[]

  @@map("companies")
  @@schema("app")
}

model User {
  id             Int                  @id @default(autoincrement())
  email          String?              @unique
  password       String?
  firstname      String?
  lastname       String?
  lastlogin      DateTime?            @db.Timestamptz(6)
  createddate    DateTime             @default(now()) @db.Timestamptz(6)
  isblocked      Boolean?             @default(false)
  userroleid     Int?
  phone          String?
  companyId      Int?                 @map("company_id")
  confirmedWeeks ConfirmedWeek[]
  logs           Log[]
  messages       Message[]
  shifts         Shift[]
  pushTokens     UserPushToken[]
  unavailability UserUnavailability[]
  role           Role?                @relation(fields: [userroleid], references: [id])
  company        Company?             @relation(fields: [companyId], references: [id])
  siteAccess     UserSiteAccess[]

  @@map("users")
  @@schema("app")
}

model Role {
  id    Int     @id
  name  String?
  users User[]

  @@map("roles")
  @@schema("app")
}

model Site {
  id         Int              @id @default(autoincrement())
  name       String?
  companyId  Int?             @map("company_id")
  positions  Position[]
  shifts     Shift[]
  userAccess UserSiteAccess[]
  company    Company?         @relation(fields: [companyId], references: [id])

  @@map("sites")
  @@schema("app")
}

model Position {
  id        Int       @id @default(autoincrement())
  name      String?
  color     String?
  starttime DateTime? @db.Time(6)
  endtime   DateTime? @db.Time(6)
  siteid    Int?
  deleted   Boolean?
  companyId Int?      @map("company_id")
  shifts    Shift[]
  site      Site?     @relation(fields: [siteid], references: [id])
  company   Company?  @relation(fields: [companyId], references: [id])

  @@map("positions")
  @@schema("app")
}

model Shift {
  id         Int       @id @default(autoincrement())
  date       DateTime  @db.Date
  positionId Int?      @map("position_id")
  published  Boolean   @default(false)
  userId     Int       @map("user_id")
  starttime  DateTime? @db.Time(6)
  endtime    DateTime? @db.Time(6)
  siteid     Int?
  companyId  Int?      @map("company_id")
  position   Position? @relation(fields: [positionId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  site       Site?     @relation(fields: [siteid], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])

  @@map("shifts")
  @@schema("app")
}

model UserUnavailability {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @db.Date
  companyId Int?     @map("company_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id])

  @@unique([userId, date])
  @@map("user_unavailability")
  @@schema("app")
}

model UserPushToken {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  token     String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  companyId Int?      @map("company_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id])

  @@unique([userId, token])
  @@map("user_push_tokens")
  @@schema("app")
}

model Message {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  title     String    @db.VarChar(255)
  body      String
  read      Boolean?  @default(false)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  companyId Int?      @map("company_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id])

  @@index([createdAt(sort: Desc)], map: "idx_messages_created_at")
  @@index([userId], map: "idx_messages_user_id")
  @@index([userId, read], map: "idx_messages_user_unread")
  @@map("messages")
  @@schema("app")
}

model ConfirmedWeek {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  confirmed Boolean  @default(false)
  userId    Int      @map("user_id")
  companyId Int?     @map("company_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id])

  @@map("confirmedweeks")
  @@schema("app")
}

model Log {
  id          Int       @id @default(autoincrement())
  createddate DateTime? @default(now()) @db.Timestamptz(6)
  userId      Int       @map("user_id")
  action      String?
  companyId   Int?      @map("company_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id])

  @@map("logs")
  @@schema("app")
}

model UserSiteAccess {
  userId Int  @map("user_id")
  siteId Int  @map("site_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site   Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_site_access")
  @@schema("app")
}

model PasswordResetCode {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("password_reset_codes")
  @@schema("app")
}

